# Local Shopify-validation env for the Spring backend.
# Copy to forestock-backend/.env for local runs.

JWT_SECRET=replace-with-a-long-random-secret
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=ChangeMe123!

FORESTOCK_FRONTEND_URL=http://localhost:5173
FORESTOCK_ALERT_EMAIL=alerts@example.com
FORESTOCK_NOTIFICATIONS_ALERT_EMAIL=ops@example.com

SHOPIFY_PROVISIONING_SECRET=dev-provisioning-secret
SHOPIFY_WEBHOOK_SECRET=dev-test-secret
SHOPIFY_ENABLED=true
SHOPIFY_AUTO_FORECAST=true

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.com
