# Docker image to run for the backend app container.
BACKEND_IMAGE=123456789012.dkr.ecr.eu-central-1.amazonaws.com/forestock-backend:example-tag

# Neon PgBouncer connection URL used by the application runtime.
NEON_POOLER_URL=jdbc:postgresql://example-pooler-host/neondb?sslmode=require

# Neon direct connection URL used by Flyway migrations.
NEON_DIRECT_URL=jdbc:postgresql://example-direct-host/neondb?sslmode=require

# Shared Neon database username for runtime and Flyway.
NEON_USERNAME=example_user

# Shared Neon database password for runtime and Flyway.
NEON_PASSWORD=example_password

# AWS access key used by the app for S3/SNS access when no instance role is available.
AWS_ACCESS_KEY_ID=EXAMPLEACCESSKEY

# AWS secret key paired with AWS_ACCESS_KEY_ID.
AWS_SECRET_ACCESS_KEY=example-secret-key

# AWS region for S3, SNS, and ECR interactions.
AWS_REGION=eu-central-1

# S3 bucket that stores forecast input backups and reports.
AWS_S3_BUCKET=example-forecast-bucket

# SNS topic ARN for forecast completion/failure notifications.
AWS_SNS_TOPIC_ARN=arn:aws:sns:eu-central-1:123456789012:example-topic

# JWT signing secret for access and refresh tokens.
JWT_SECRET=replace-with-a-long-random-secret

# Allowed frontend origin and password-reset base URL.
FORESTOCK_FRONTEND_URL=https://app.example.com

# Alert email recipient for forecast notifications.
FORESTOCK_ALERT_EMAIL=alerts@example.com

# Username for the one-time seeded super-admin account.
SUPER_ADMIN_USERNAME=superadmin

# Password for the one-time seeded super-admin account.
SUPER_ADMIN_PASSWORD=ChangeMe123!

# SMTP host used for password reset emails.
MAIL_HOST=smtp.example.com

# SMTP port used for password reset emails.
MAIL_PORT=587

# SMTP username for the mail sender account.
MAIL_USERNAME=mailer@example.com

# SMTP password for the mail sender account.
MAIL_PASSWORD=example-mail-password

# From address shown on outgoing password reset emails.
MAIL_FROM=noreply@example.com

# Shopify webhook HMAC secret used to verify incoming orders/create webhooks.
SHOPIFY_WEBHOOK_SECRET=example-shopify-webhook-secret

# Enables or disables Shopify webhook processing endpoints.
SHOPIFY_ENABLED=false

# Automatically trigger forecasts after successful Shopify order ingestion.
SHOPIFY_AUTO_FORECAST=true

# Redis hostname for the token blacklist cache.
REDIS_HOST=redis

# Redis port for the token blacklist cache.
REDIS_PORT=6379

# Optional Redis password if authentication is enabled.
REDIS_PASSWORD=
