SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_APP_URL=https://your-shopify-app-host
SCOPES=read_products,read_inventory,read_orders

# Shopify app session storage
# Use a dedicated Postgres/Neon database or schema for Shopify sessions.
DATABASE_URL=postgresql://your_user:your_password@your-postgres-host/your_shopify_sessions_db?sslmode=require

# Forestock backend integration
FORESTOCK_API_BASE_URL=http://localhost:8080
FORESTOCK_PROVISIONING_SECRET=dev-provisioning-secret
